version: '3.8'

services:
  # --- Backend Service ---
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: node_backend
    ports:
      - "5000:5000"      
    environment:
      - NODE_ENV=development
      - PORT=5000
    networks:
      - app-network

  # --- Frontend Service ---
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: react_frontend
    ports:
      - "3000:3000"
    environment:
      - WATCHPACK_POLLING=true # Ensures hot-reloading works smoothly inside Docker on all OS platforms
    stdin_open: true # Keeps the container interactive (required for React scripts)
    tty: true        # Allocates a pseudo-TTY (required for React scripts)
    depends_on:
      - backend      # Starts the backend service before launching the frontend
    networks:
      - app-network

# --- Shared Network ---
networks:
  app-network:
    driver: bridge
